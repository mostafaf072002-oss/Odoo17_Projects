<?xml version="1.0" encoding="utf-8"?>
<odoo>
    # ------------- Student Seq ------------- #
    <record id="seq_school_student" model="ir.sequence">
        <field name="name">Student ID</field>
        <field name="code">school.student</field>
        <field name="prefix">STU/%(year)s/</field>
        <field name="padding">4</field>
    </record>
    # ------------- Teacher Seq ------------- #
    <record id="seq_school_teacher" model="ir.sequence">
        <field name="name">Teacher ID</field>
        <field name="code">school.teacher</field>
        <field name="prefix">TCH/%(year)s/</field>
        <field name="padding">3</field>
    </record>
    <record id="seq_school_fee" model="ir.sequence">
        <field name="name">Fee Reference</field>
        <field name="code">school.fee</field>
        <field name="prefix">FEE/%(year)s/</field>
        <field name="padding">4</field>
    </record>
</odoo>
