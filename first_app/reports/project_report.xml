<odoo>
<!-- ======================= Report Action ======================= -->
    <record id="project_report_action" model="ir.actions.report">
        <field name="name">Project Report</field>
        <field name="model">project.project</field>
        <field name="binding_model_id" ref="model_project_project"/>

        <field name="report_type">qweb-pdf</field>
        <field name="report_name">first_app.project_report_template</field>
    </record>

    <template id="project_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="rec">
                <style>
                    table, th, td {
                        border: 0px !important;
                        box-shadow: none !important;
                    }
                    div h1 {
                        text-align:center;
                    }
                    table {
                        width: 80%;
                        text-align: center;
                        margin: 30px auto;
                    }
                    table td {
                        padding: 10px;
                    }
                </style>
                    <div>
                        <h1>Project Report</h1>
                        <table>
                            <thead>
                                <tr>
                                    <td colspan="4"><h2>Info</h2></td>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Project Name</td>
                                    <td><t t-esc="rec.name"/></td>
                                    <td>Employee</td>
                                    <td><t t-esc="rec.staff_id.name"/></td>
                                </tr>
                            </tbody>
                        </table>

                    </div>
            </t>
            </t>
        </t>
    </template>
</odoo>

