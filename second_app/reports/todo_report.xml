<odoo>
    <record id="todo_report_action" model="ir.actions.report">
        <field name="name">Task Report</field>
        <field name="model">todo.task</field>
        <field name="binding_model_id" ref="model_todo_task"/>
        <field name="binding_type">report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">second_app.todo_template_report</field>
    </record>
    <template id="todo_template_report">

            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <t t-foreach="docs" t-as="o">
                        <style>
                            table, th, td {
                                border: 0 !important;
                            }
                            table {
                                width:100%;
                                text-align:center;
                                border-collapse: collapse;
                            }
                            table thead th {
                                padding:10px;
                            }
                            table tbody tr td {
                                padding:10px;
                            }
                        </style>
                        <h1>Report</h1>
                        <table>
                            <thead>
                                <th colspan="4">Info</th>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Name</td>
                                    <td><t t-esc="o.name"/></td>
                                    <td>Description</td>
                                    <td><t t-esc="o.description"/></td>
                                </tr>
                                <tr>
                                    <td>Assign To</td>
                                    <td><t t-esc="o.assign_to.name"/></td>
                                    <td>Due To</td>
                                    <td><t t-esc="o.due_date"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                </t>
            </t>
    </template>
</odoo>