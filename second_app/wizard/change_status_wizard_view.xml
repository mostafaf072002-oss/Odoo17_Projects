<odoo>
    <!-- ================== Form View ================== -->
    <record id="change_status_form" model="ir.ui.view">
        <field name="name">change.status</field>
        <field name="model">change.status</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                        <group>
                            <group>
                                <field name="task_id" invisible="1"/>
                                <field name="status" required="1"/>
                            </group>
                            <group>
                                <field name="reason" required="1"/>
                            </group>
                        </group>

                   <footer>
                       <button name="action_completed" type="object" string="Change" class="btn-primary"/>
                   </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================== Action ================== -->
    <record id="change_status_wizard_action" model="ir.actions.act_window">
        <field name="name">Change Status</field>
        <field name="res_model">change.status</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>
</odoo>