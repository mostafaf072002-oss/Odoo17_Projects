<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="property_report" model="ir.actions.report">
        <field name="name">Property Report</field>
        <field name="model">real.estate.property</field>
        <field name="binding_model_id" ref="model_real_estate_property"/>
        <field name="binding_type">report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">real_estate.property_template</field>
        <field name="report_name">real_estate.property_template</field>
    </record>

    <!-- ========= Report Template ========= -->

    <template id="property_template">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="doc">

                <t t-call="web.external_layout">

                    <div class="page">

                        <h2>
                            Property Report
                        </h2>

                        <br/>

                        <table class="table table-bordered">

                            <tbody>

                                <tr>
                                    <th>Name</th>
                                    <td>
                                        <span t-field="doc.name"/>
                                    </td>
                                </tr>

                                <tr>
                                    <th>State</th>
                                    <td>
                                        <span t-field="doc.state"/>
                                    </td>
                                </tr>

                                <tr>
                                    <th>Price</th>
                                    <td>
                                        <span t-field="doc.selling_price"/>
                                    </td>
                                </tr>

                                <tr>
                                    <th>Date Available</th>
                                    <td>
                                        <span t-field="doc.date_available"/>
                                    </td>
                                </tr>

                            </tbody>

                        </table>

                    </div>

                </t>

            </t>

        </t>

    </template>
</odoo>