<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_grade_report_wizard_form" model="ir.ui.view">
        <field name="name">school.grade.report.wizard.form</field>
        <field name="model">school.grade.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Grade Report">
                <group string="Filter Criteria">
                    <field name="classroom_id"/>
                    <field name="subject_id"/>
                    <field name="exam_type"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_print_report" string="Print PDF Report"
                            type="object" class="btn-primary"/>
                    <button name="action_view_results" string="View Results"
                            type="object" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_grade_report_wizard" model="ir.actions.act_window">
        <field name="name">Grade Report</field>
        <field name="res_model">school.grade.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
