<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Category ─────────────────────────────────────── -->
    <record id="module_school_system" model="ir.module.category">
        <field name="name">School System</field>
        <field name="sequence">100</field>
    </record>

    <!-- ── Groups ───────────────────────────────────────── -->
    <record id="group_school_student" model="res.groups">
        <field name="name">Student</field>
        <field name="category_id" ref="module_school_system"/>
    </record>

    <record id="group_school_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="category_id" ref="module_school_system"/>
        <field name="implied_ids" eval="[(4, ref('group_school_student'))]"/>
    </record>

    <record id="group_school_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_school_system"/>
        <field name="implied_ids" eval="[(4, ref('group_school_teacher'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- ── Record Rules ──────────────────────────────────── -->
    <!-- Teachers can only see their own classes -->
    <record id="rule_teacher_own_classes" model="ir.rule">
        <field name="name">Teacher: Own Classes Only</field>
        <field name="model_id" ref="model_school_classroom"/>
        <field name="domain_force">[('teacher_id.name', '=', user.name)]</field>
        <field name="groups" eval="[(4, ref('group_school_teacher'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Managers see everything -->
    <record id="rule_manager_all_access" model="ir.rule">
        <field name="name">Manager: Full Access</field>
        <field name="model_id" ref="model_school_student"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_school_manager'))]"/>
    </record>
</odoo>
