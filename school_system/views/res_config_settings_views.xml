<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Settings ─────────────────────────────── -->
    <record id="view_school_config_settings" model="ir.ui.view">
        <field name="name">school.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='integration_settings']" position="after">
                <h2>School System Integration</h2>
                <div class="row mt16">
                    <label for="school_external_api_url" class="col-lg-3 o_light_label"/>
                    <field name="school_external_api_url" class="col-lg-7"
                           placeholder="https://api.example.com"/>
                </div>
                <div class="row mt16">
                    <label for="school_external_api_key" class="col-lg-3 o_light_label"/>
                    <field name="school_external_api_key" class="col-lg-7" password="True"/>
                </div>
                <div class="row mt16">
                    <label for="school_sms_api_key" class="col-lg-3 o_light_label"/>
                    <field name="school_sms_api_key" class="col-lg-7" password="True"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_school_config_settings" model="ir.actions.act_window">
        <field name="name">School Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>
</odoo>
