<odoo>
    <record id="product_form_inherit" model="ir.ui.view">
        <field name="name">Product Form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='name']" position="before">
                    <div>
                        <h1>
                            <label for="ref"/>
                            <field name="ref"/>
                        </h1>
                    </div>
            </xpath>
            <xpath expr="//field[@name='invoice_policy']" position="after">
                <field name="is_plumbing"/>
                <field name="material"/>
                <field name="brand"/>
                <field name="diameter"/>
                <field name="margin"/>
            </xpath>
            <xpath expr="//field[@name='margin']" position="before">
                <field name="min_quantity"/>
                <field name="is_low_stock"/>
            </xpath>

        </field>
    </record>

    <!-- ============== Cron Action (Check Low Stock) ============== -->
    <record id="cron_low_stock_products" model="ir.cron">
            <field name="name">Check Low Stock Products</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="state">code</field>
            <field name="code">model.check_low_stock()</field>

            <!-- Run every day -->
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

    <!-- ============== Server Action (Check Low Stock) ============== -->
    <record id="server_low_stock_products" model="ir.actions.server">
            <field name="name">Check Low Stock Products</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="binding_model_id" ref="product.model_product_template"/>
            <field name="state">code</field>
            <field name="code">records.check_low_stock()</field>
    </record>
</odoo>