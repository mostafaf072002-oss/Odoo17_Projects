<odoo>
    <record id="quick_sale_wizard_view" model="ir.ui.view">
        <field name="name">quick.sale.wizard</field>
        <field name="model">quick.sale.order.wizard</field>
        <field name="arch" type="xml">
            <form string="Quick Sale">
                <group>
                    <field name="partner_id"/>
                    <field name="product_id"/>
                    <field name="quantity"/>
                </group>
                <footer>
                    <button name="create_order"
                            type="object"
                            string="Create"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_quick_sale_wizard" model="ir.actions.act_window">
        <field name="name">Quick Sale</field>
        <field name="res_model">quick.sale.order.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>